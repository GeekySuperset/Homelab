# Copy to .env in this directory before `docker compose up`.
# Create the `proxy` network first: deploy bootstrap or `docker network create proxy`.

COMPOSE_PROJECT_NAME=homelab-personal

# Optional: Hardcover API token for Calibre Web Automated (leave unset if unused).
HARDCOVER_TOKEN=

# Glance Pi-hole dns-stats widget reads stacks/personal/glance/config/home.yml (not Compose).
# Set its password to the same value as PIHOLE_WEB_PASSWORD in bootstrap/.env.
